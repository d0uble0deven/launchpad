# ─────────────────────────────────────────────────────────────────
# LaunchPad — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────
PORT=3001
DATABASE_PATH=./data/launchpad.db

# Base URL used for "Open Task" buttons in Slack messages
APP_BASE_URL=http://localhost:5173

# ── Slack credentials (get these from https://api.slack.com/apps) ──
# See docs/SLACK_SETUP.md for step-by-step setup instructions.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── Slack safety rails (see docs/GO_LIVE.md) ────────────────────────
# Master switch. Keep false while building — no Slack API calls are
# made at all; every would-be DM is logged to the terminal and recorded
# in the notification history instead.
SLACK_ENABLED=false

# Only these Slack user IDs may receive their own DMs directly.
# Everyone else's messages are redirected (below) or dropped.
# Find yours: Slack profile → ⋮ menu → "Copy member ID"
SLACK_DM_ALLOWLIST=

# Where non-allowlisted users' messages are delivered instead, with a
# "🧪 Test redirect — intended for X" banner. Set to your own user ID
# while testing. Leave blank to silently drop instead.
SLACK_REDIRECT_TO=

# Prefix every outgoing message with a 🧪 test disclaimer
SLACK_TEST_MODE=true

# ── Owner → Slack user mapping ──────────────────────────────────────
# Maps board swimlane ids to Slack user IDs. Lanes with an empty value
# are skipped (recorded in history as "skipped — no Slack mapping").
# The "employee" lane is usually unmapped: the hire's Slack account is
# created BY the onboarding process.
OWNER_SLACK_MAP=employee=,justin=,hiring-supervisor=,paras=,automation=,jana=,melissa=,anupe=,sheila=,project-lead=,becca=
